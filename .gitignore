# Dataset (large files)
# Note: dataset/prepared/ is included in Git for easy deployment
dataset/raw/*.wav
dataset/wav/*.wav
dataset/*.csv
!dataset/prepared/*.csv
!dataset/prepared/*.json
!dataset/prepared/wav/*.wav
!dataset/raw/.gitkeep
!dataset/wav/.gitkeep

# Training artifacts
training/**
!training/.gitkeep
dataset/prepared/training/**
checkpoints/*.ckpt
checkpoints/**/*.ckpt
!checkpoints/.gitkeep
lightning_logs/

# Models (large files)
models/*.onnx
models/*.json
!models/.gitkeep

# Logs
logs/*.log
logs/*.json
logs/*.txt
!logs/.gitkeep

# Temporary files
*.tmp
*.bak
*.swp

# UV
.uv/
